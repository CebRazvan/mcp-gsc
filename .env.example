# Template for the env vars Dokploy/docker-compose will read.
# Copy to .env for local testing (.env is gitignored and dockerignored).
# For Dokploy deployment, set these directly in the Dokploy UI —
# do NOT put real secrets in .env committed to git.

# Transport: streamable-http for remote MCP (Claude.ai connectors, reverse proxy)
MCP_TRANSPORT=streamable-http
MCP_HOST=0.0.0.0
MCP_PORT=3001
MCP_PATH=/mcp

# GSC auth — service account only for server deployment
GSC_SKIP_OAUTH=true
GSC_CREDENTIALS_PATH=/run/secrets/gsc_sa.json

# Where the module-level makedirs() writes (platformdirs default uses $HOME,
# which doesn't exist for the non-root container user). Already set in
# Dockerfile ENV — listed here for documentation.
GSC_CONFIG_DIR=/app/.config/mcp-gsc

# GSC data freshness: "all" (matches dashboard) or "final" (2-3 day lag)
GSC_DATA_STATE=all

# Safety: keep false unless you need add_site / delete_site / delete_sitemap.
# These require Owner permission which Service Accounts cannot obtain anyway.
GSC_ALLOW_DESTRUCTIVE=false

# ---------------------------------------------------------------------------
# Bearer-token authentication (STRONGLY RECOMMENDED for public endpoints).
#
# If UNSET (default): no auth. Any client with the URL can call every tool.
#   Only safe for local stdio use.
#
# If set: every request must include:
#     Authorization: Bearer <this exact value>
#   or it gets HTTP 401. Comparison is timing-safe (hmac.compare_digest).
#
# Generate with:  openssl rand -hex 32
# MCP_BEARER_TOKEN=4f8a...replace-me-with-openssl-rand-hex-32...b2c1
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# DNS rebinding protection (optional hardening).
#
# If UNSET (default): protection is DISABLED — the server trusts whatever Host
#   header the reverse proxy forwards. This is the right default for a
#   production deployment behind Traefik / Cloudflare — DNS rebinding is a
#   browser / local-dev threat, not a public-HTTPS threat.
#
# If set: protection is ENABLED and only the listed hosts/origins are allowed.
#   Anything else → HTTP 421 Misdirected Request.
#
# MCP_ALLOWED_HOSTS=gsc.lucramresponsabil.com,gsc.lucramresponsabil.com:*
# MCP_ALLOWED_ORIGINS=https://claude.ai,https://claude.com
# ---------------------------------------------------------------------------
